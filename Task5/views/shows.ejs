<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TV Shows</title>
    <link rel="stylesheet" href="/css/index.css">
</head>

<body>
    <div class="container">
        <header>
            <div class="home-content">
                <h1>TV Shows</h1>
                <nav>
                    <a href="/schedule">Schedule</a> | <a href="/shows">Shows</a> | <a href="/channels">Channels</a>
                </nav>
            </div>
        </header>

        <main>
            <form action="/shows" method="GET" style="margin-bottom: 20px;">
                <input type="text" name="search" placeholder="Пошук за назвою..." value="<%= search %>">
                <input type="hidden" name="limit" value="<%= limit %>">
                <button type="submit">Знайти</button>
                <a href="/shows">Скинути</a>
            </form>

            <% if (shows && shows.length> 0) { %>
                <ul class="team-list">
                    <% shows.forEach(function(show) { %>
                        <li style="display: flex; justify-content: space-between; align-items: center; gap: 10px;">
                            <a href="#">
                                <span><strong>ID:</strong>
                                    <%= show.id %>
                                </span>
                                <span>
                                    <%= show.title %>
                                </span>
                            </a>
                            <% if (user && user.role==='ADMIN' ) { %>
                                <div style="display:flex; gap:8px;">
                                    <form action="/shows/<%= show.id %>/update" method="POST"
                                        style="display:flex; gap:6px; align-items:center; margin:0;">
                                        <input type="text" name="title" value="<%= show.title %>" required>
                                        <button type="submit"
                                            style="background:#1e90ff; color:white; padding:5px 10px;">Оновити</button>
                                    </form>
                                    <form action="/shows/<%= show.id %>/delete" method="POST" style="margin:0;">
                                        <button type="submit"
                                            style="background:red; color:white; padding:5px 10px;">Видалити</button>
                                    </form>
                                </div>
                                <% } %>
                        </li>
                        <% }); %>
                </ul>

                <div style="margin-top: 20px; text-align: center;">
                    <% if (currentPage> 1) { %>
                        <a
                            href="/shows?page=<%= currentPage - 1 %>&limit=<%= limit %>&search=<%= search %>">Попередня</a>
                        <% } %>

                            <span style="margin: 0 10px;">Сторінка <%= currentPage %> з <%= totalPages %></span>

                            <% if (currentPage < totalPages) { %>
                                <a
                                    href="/shows?page=<%= currentPage + 1 %>&limit=<%= limit %>&search=<%= search %>">Наступна</a>
                                <% } %>
                </div>
                <% } else { %>
                    <p>Нічого не знайдено.</p>
                    <% } %>

        </main>

        <footer>
            <a href="/">Back to Home</a>
        </footer>
    </div>
</body>

</html>